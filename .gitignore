# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── WhatsApp scraper bot — Chromium session (huge, not needed for deployment) ──
apps/whatsapp-scraper-bot/.wwebjs_auth/
apps/whatsapp-scraper-bot/.wwebjs_cache/
apps/whatsapp-scraper-bot/node_modules/

# ── Firebase service account keys (never commit!) ──
*service-account*.json
*serviceAccount*.json
firebase-adminsdk*.json

# ── Large binary / archive folders ──
*.zip
*.rar
*.7z
*.tar
*.tar.gz
"claude fi 28-4"/
claude*/
archive*/
Archive*/
__archive*/

# ── IDE / OS artifacts ──
.idea/
.vscode/settings.json
Thumbs.db

# ── Misc large data ──
*.heapsnapshot
*.cpuprofile
apps/whatsapp-scraper-bot/.wwebjs_auth/**
